generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── PROPERTIES ───────────────────────────────────────────────────────────────
model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  password   String   // hashed — never store plain text
  role       String   @default("Editor") // legacy display field kept in sync with assignedRole.name
  roleId     Int?
  permissionsVersion Int @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  lastActive DateTime?

  assignedRole     Role?           @relation("AssignedRole", fields: [roleId], references: [id], onDelete: SetNull)
  assignedShowings Showing[]       @relation("AssignedShowings")
  assignedMessages ContactMessage[] @relation("AssignedMessages")
}
model Property {
  id            Int       @id @default(autoincrement())
  title         String
  titleAr       String?   // Arabic translation
  price         String
  address       String
  neighbourhood String
  status        String    // "For Sale" | "For Rent" | "New Development"
  type          String    // "Estate" | "Villa" | "Penthouse" | "Townhouse" | "Apartment"
  bedrooms      Int
  bathrooms     Float
  area          String
  yearBuilt     String?
  lotSize       String?
  description   String?
  descriptionAr String?   // Arabic translation
  features      String[]
  featuresAr    String[]  // Arabic translations of features
  images        String[]  // array of image URLs
  agentName     String?
  isPublished   Boolean   @default(false)
  listingExpiresAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  showings      Showing[]
}

// ─── BLOG ─────────────────────────────────────────────────────────────────────

model BlogPost {
  id          Int      @id @default(autoincrement())
  title       String
  titleAr     String?  // Arabic translation
  slug        String   @unique
  topic       String
  author      String
  subtitle    String?
  subtitleAr  String?  // Arabic translation
  body        String
  bodyAr      String?  // Arabic translation
  pullQuote   String?
  pullQuoteAr String?  // Arabic translation
  heroImage   String?
  readTime    String?
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── NEWS ─────────────────────────────────────────────────────────────────────

model NewsArticle {
  id          Int      @id @default(autoincrement())
  title       String
  titleAr     String?  // Arabic translation
  slug        String   @unique
  category    String
  author      String
  summary     String
  summaryAr   String?  // Arabic translation
  body        String
  bodyAr      String?  // Arabic translation
  heroImage   String?
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── SHOWINGS & CONTACT ───────────────────────────────────────────────────────

model Showing {
  id           Int      @id @default(autoincrement())
  type         String   // "showing" | "agent_enquiry"
  propertyId   Int?
  propertyName String
  name         String
  email        String
  phone        String?
  date         String?
  time         String?
  message      String
  status       String   @default("New") // "New" | "Confirmed" | "Completed" | "Cancelled"
  assignedToId Int?
  createdAt    DateTime @default(now())

  property     Property? @relation(fields: [propertyId], references: [id])
  assignedTo   User?     @relation("AssignedShowings", fields: [assignedToId], references: [id], onDelete: SetNull)
}

model ContactMessage {
  id           Int      @id @default(autoincrement())
  name         String
  email        String
  phone        String?
  message      String
  status       String   @default("Unread") // "Unread" | "Read" | "Replied"
  assignedToId Int?
  createdAt    DateTime @default(now())

  assignedTo   User?    @relation("AssignedMessages", fields: [assignedToId], references: [id], onDelete: SetNull)
}

// ─── USERS ────────────────────────────────────────────────────────────────────



model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  description     String?
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  users           User[]           @relation("AssignedRole")
  rolePermissions RolePermission[]
}

model Permission {
  id              Int              @id @default(autoincrement())
  key             String           @unique
  label           String
  description     String?
  group           String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       Int
  permissionId Int

  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model SiteContent {
  id         Int      @id @default(autoincrement())
  key        String   @unique  // "home_hero", "home_cta", "about_story", "service_1" etc.
  title      String?
  titleAr    String?  // Arabic translation
  subtitle   String?
  subtitleAr String?  // Arabic translation
  body       String?
  bodyAr     String?  // Arabic translation
  image      String?
  linkText   String?
  linkTextAr String?  // Arabic translation
  linkUrl    String?
  updatedAt  DateTime @updatedAt
}
